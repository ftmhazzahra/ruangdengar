# ==================== PRODUCTION ENVIRONMENT CONFIGURATION ====================
# Copy file ini ke .env dan isi semua variabel yang diperlukan
# JANGAN share .env ke public repository!

# ==================== SECURITY ====================
DJANGO_ENV=production
DEBUG=False

# Generate SECRET_KEY baru dengan command:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-generated-secret-key-here

# Allowed hosts (pisahkan dengan koma, tanpa spasi)
ALLOWED_HOSTS=157.66.34.207,ruangdengar.cloud,www.ruangdengar.cloud

# ==================== DATABASE (PostgreSQL) ====================
# WAJIB diisi untuk production!
DB_ENGINE=django.db.backends.postgresql
DB_NAME=ruangdengar_db
DB_USER=ruangdengar_user
DB_PASSWORD=your-strong-db-password-here
DB_HOST=localhost
DB_PORT=5432

# ==================== EMAIL CONFIGURATION ====================
# WAJIB diisi untuk production agar email dapat dikirim!
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-from-gmail

# Email pengirim (boleh sama dengan EMAIL_HOST_USER)
DEFAULT_FROM_EMAIL=your-email@gmail.com

# ==================== SITE CONFIGURATION ====================
# URL lengkap site (untuk link dalam email)
SITE_URL=https://ruangdengar.cloud

# ==================== OPTIONAL SETTINGS ====================
# Cache (Redis) - optional untuk production
# REDIS_URL=redis://localhost:6379/0

# ==================== INSTRUCTIONS ====================
# 1. Generate SECRET_KEY baru:
#    python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
#
# 2. Untuk EMAIL_HOST_PASSWORD dengan Gmail:
#    - Enable 2-Factor Authentication di Google Account
#    - Generate App Password: https://myaccount.google.com/apppasswords
#    - Gunakan password yang dihasilkan
#
# 3. Pastikan semua REQUIRED fields sudah diisi sebelum deploy!
#
# 4. Setup PostgreSQL:
#    - Create database: createdb ruangdengar_db
#    - Create user: createuser ruangdengar_user
#    - Grant privileges: ALTER ROLE ruangdengar_user CREATEDB;
#
# 5. Run migrations:
#    python manage.py migrate --settings=ruangdengar.settings_production
#
# 6. Create superuser:
#    python manage.py createsuperuser --settings=ruangdengar.settings_production
#
# 7. Collect static files:
#    python manage.py collectstatic --noinput --settings=ruangdengar.settings_production
#
# 8. Run with gunicorn:
#    gunicorn ruangdengar.wsgi:application --workers 4 --bind 0.0.0.0:8000
